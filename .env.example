# ─────────────────────────────────────────────────────────
# NAVAGRAHA — Environment Variables
# Copy this file to .env and fill in your credentials
# ─────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Public URL of your deployed app (used for payment callbacks)
# Example: https://navagraha.replit.app
APP_URL=https://your-app.replit.app

# ─── Database (Neon PostgreSQL) ───────────────────────────
# Get yours at: https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname
PGHOST=your-neon-host.neon.tech
PGPORT=5432
PGUSER=your-username
PGPASSWORD=your-password
PGDATABASE=your-database

# ─── Session ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-very-long-random-secret

# ─── Google Maps (for place autocomplete in Kundli) ───────
# Get yours at: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=AIza...

# ─── Vedic Astrology API (optional) ──────────────────────
# Without this, app uses high-quality mock data
# Get API key at: https://www.vedicastroapi.com
VEDIC_ASTRO_API_KEY=
VEDIC_ASTRO_USER_ID=

# ─────────────────────────────────────────────────────────
# PAYMENT GATEWAYS
# ─────────────────────────────────────────────────────────

# ─── Razorpay (PRIMARY — required for real payments) ──────
# Sign up at: https://dashboard.razorpay.com
# Snapmint EMI & LazyPay BNPL are available natively within
# Razorpay Checkout — enable in Dashboard → Payment Methods
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Webhook secret: Razorpay Dashboard → Webhooks → Create
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Snapmint Direct (OPTIONAL — standalone EMI checkout) ─
# Snapmint EMI is also available inside Razorpay Checkout
# For standalone integration, apply at: https://snapmintbusiness.com/connect
# Credentials: Merchant ID, API Key (HMAC secret), Token (Bearer auth)
SNAPMINT_MERCHANT_ID=
SNAPMINT_API_KEY=
SNAPMINT_TOKEN=

# ─── LazyPay / PayU BNPL (OPTIONAL) ──────────────────────
# LazyPay is available inside Razorpay Checkout (easiest path)
# For standalone PayU integration:
#   1. Apply for merchant account: https://onboarding.payu.in
#   2. Enable LazyPay in PayU dashboard
#   3. Add credentials below
# API docs: https://docs.payu.in
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=

# ─────────────────────────────────────────────────────────
# VOICE & VIDEO CALLS
# ─────────────────────────────────────────────────────────

# ─── Agora RTC (required for voice/video calls) ───────────
# Sign up at: https://www.agora.io — 10,000 free minutes/month
# Create a project → copy App ID and App Certificate
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ─────────────────────────────────────────────────────────
# OPTIONAL: NOTIFICATIONS
# ─────────────────────────────────────────────────────────

# Email (for booking confirmations, receipts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@navagraha.app

# Firebase Cloud Messaging (push notifications — future)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
