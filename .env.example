# ═══════════════════════════════════════════════════════════════
# NAVAGRAHA — Environment Variables Reference
# ═══════════════════════════════════════════════════════════════
#
# HOW TO USE
# ──────────
# Local dev : copy to .env and fill in values
# Railway   : paste each variable into Railway Dashboard →
#             Your Project → Variables → Raw Editor
#
# LEGEND
# ──────
# [REQUIRED]  App will crash or core features break without this
# [OPTIONAL]  Feature degrades gracefully or has a mock fallback
# [RAILWAY]   Set automatically by Railway — do not set manually
#
# ═══════════════════════════════════════════════════════════════
# 1. APP
# ═══════════════════════════════════════════════════════════════

# [REQUIRED] Set to "production" on Railway
NODE_ENV=production

# [RAILWAY] Railway injects PORT automatically — do not set this
# PORT=5000

# [REQUIRED] The public HTTPS URL Railway gives your service
# Find it: Railway Dashboard → Your Service → Settings → Domains
# Used for: Razorpay / Snapmint / LazyPay payment callback URLs
APP_URL=https://your-service.up.railway.app

# ═══════════════════════════════════════════════════════════════
# 2. DATABASE  (PostgreSQL)
# ═══════════════════════════════════════════════════════════════
#
# Option A — Railway PostgreSQL plugin (recommended, easiest)
#   Add the Postgres plugin to your Railway project.
#   Railway auto-injects DATABASE_URL, PGHOST, PGPORT, PGUSER,
#   PGPASSWORD, PGDATABASE — nothing to set manually.
#   After first deploy run:  railway run npm run db:push
#
# Option B — External Neon DB (neon.tech)
#   Paste the connection string from your Neon dashboard below.
#
# [REQUIRED]
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Only needed for Option B (external DB):
PGHOST=your-db-host
PGPORT=5432
PGUSER=your-db-user
PGPASSWORD=your-db-password
PGDATABASE=your-db-name

# ═══════════════════════════════════════════════════════════════
# 3. SESSION
# ═══════════════════════════════════════════════════════════════

# [REQUIRED] Long random string — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-64-hex-chars

# ═══════════════════════════════════════════════════════════════
# 4. USER AUTHENTICATION — Google OAuth 2.0
# ═══════════════════════════════════════════════════════════════
#
# HOW TO CREATE CREDENTIALS:
#   1. Go to https://console.cloud.google.com
#   2. APIs & Services → Credentials → Create Credentials → OAuth client ID
#   3. Application type: Web application
#   4. Authorised redirect URIs — add BOTH:
#        http://localhost:5000/api/auth/google/callback   (local dev)
#        https://<your-railway-domain>/api/auth/google/callback
#   5. Copy Client ID and Client Secret below
#
# [REQUIRED] for user login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ═══════════════════════════════════════════════════════════════
# 5. PROKERALA ASTROLOGY API
# ═══════════════════════════════════════════════════════════════
#
# Powers: Kundli, Kundli Matching, Daily Horoscope, Numerology
# Sign up: https://api.prokerala.com
# Dashboard → Create App → copy Client ID and Client Secret
# Free plan: 5,000 credits — enough to start
# Auth: OAuth 2.0 Client Credentials (token auto-managed by app)
#
# [REQUIRED] Falls back to mock data if not set
PROKERALA_CLIENT_ID=your_prokerala_client_id
PROKERALA_CLIENT_SECRET=your_prokerala_client_secret

# ═══════════════════════════════════════════════════════════════
# 6. GOOGLE MAPS
# ═══════════════════════════════════════════════════════════════
#
# Used for place autocomplete when entering birth city in Kundli.
# Get key: https://console.cloud.google.com → APIs → Maps JS API
# Enable: Maps JavaScript API + Places API
#
# [OPTIONAL] Birth city entry falls back to manual lat/lon input
GOOGLE_MAPS_API_KEY=AIza...

# ═══════════════════════════════════════════════════════════════
# 7. PAYMENTS — RAZORPAY  (primary gateway)
# ═══════════════════════════════════════════════════════════════
#
# Required for wallet recharges and consultation billing.
# Sign up: https://dashboard.razorpay.com
# Snapmint EMI and LazyPay BNPL work inside Razorpay Checkout
# → enable them in Razorpay Dashboard → Payment Methods
#
# Webhook setup:
#   Razorpay Dashboard → Webhooks → Add New Webhook
#   URL:    https://<your-railway-domain>/api/payment/razorpay/webhook
#   Events: payment.captured  +  payment.failed
#
# [REQUIRED] for real payments
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ═══════════════════════════════════════════════════════════════
# 8. PAYMENTS — SNAPMINT  (standalone EMI, optional)
# ═══════════════════════════════════════════════════════════════
#
# Snapmint EMI is already inside Razorpay Checkout.
# Only set these for a standalone Snapmint integration.
# Apply: https://snapmintbusiness.com/connect
#
# [OPTIONAL]
SNAPMINT_MERCHANT_ID=
SNAPMINT_API_KEY=
SNAPMINT_TOKEN=

# ═══════════════════════════════════════════════════════════════
# 9. PAYMENTS — LAZYPAY / PAYU  (BNPL, optional)
# ═══════════════════════════════════════════════════════════════
#
# LazyPay is already inside Razorpay Checkout.
# Only set these for a standalone PayU/LazyPay integration.
# Apply: https://onboarding.payu.in
#
# [OPTIONAL]
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=

# ═══════════════════════════════════════════════════════════════
# 10. VOICE & VIDEO CALLS — AGORA RTC
# ═══════════════════════════════════════════════════════════════
#
# Required for live voice/video consultations.
# Free tier: 10,000 minutes/month
# Sign up: https://www.agora.io
# Console → Create Project → copy App ID + App Certificate
#
# [REQUIRED] for voice/video — chat-only works without it
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ═══════════════════════════════════════════════════════════════
# 11. EMAIL NOTIFICATIONS  (optional)
# ═══════════════════════════════════════════════════════════════
#
# For booking confirmations and payment receipts.
# Gmail: create an App Password (not your regular Gmail password)
#   Account → Security → 2-Step Verification → App Passwords
#
# [OPTIONAL]
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM=noreply@navagraha.app

# ═══════════════════════════════════════════════════════════════
# 12. PUSH NOTIFICATIONS — FIREBASE  (future / optional)
# ═══════════════════════════════════════════════════════════════
#
# Not yet wired up in the app — leave blank for now.
#
# [OPTIONAL]
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
