# Database Configuration
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/navagraha

# Individual PostgreSQL settings (for Neon compatibility)
PGHOST=localhost
PGPORT=5432
PGUSER=your_username
PGPASSWORD=your_password
PGDATABASE=navagraha

# Session Secret
# Generate a random string for session encryption
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-very-secure-random-string-here-change-this

# Google Maps API Key
# Required for location autocomplete in kundli generation
# Get yours at: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# VedicAstroAPI Credentials (Optional)
# If not provided, the app will use mock data for astrology calculations
# Sign up at: https://vedicastroapi.com/
VEDIC_ASTRO_API_KEY=your-vedic-astro-api-key
VEDIC_ASTRO_USER_ID=your-vedic-astro-user-id

# Node Environment
NODE_ENV=development

# Optional: Frontend Environment Variables
# These must be prefixed with VITE_ to be accessible in the frontend
# VITE_API_BASE_URL=http://localhost:5000
